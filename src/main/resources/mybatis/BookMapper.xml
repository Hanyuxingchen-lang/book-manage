<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.book.mapper.BookMapper">

    <select id="selectBookByPage" resultType="Book">
        SELECT id,book_name,author,isbn,stock,create_time,update_time
        FROM book
        <where>
            <if test="dto.keyword != null and dto.keyword != ''">
                book_name LIKE CONCAT('%',#{dto.keyword},'%')
            </if>
        </where>
        LIMIT #{dto.pageNum},#{dto.pageSize}
    </select>

    <select id="countBook" resultType="Long">
        SELECT COUNT(*) FROM book
        <where>
            <if test="keyword != null and keyword != ''">
                book_name LIKE CONCAT('%',#{keyword},'%')
            </if>
        </where>
    </select>

    <select id="selectById" resultType="Book">
        SELECT * FROM book WHERE id = #{id}
    </select>

    <insert id="insert" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO book(book_name,author,isbn,stock,create_time,update_time)
        VALUES(#{bookName},#{author},#{isbn},#{stock},NOW(),NOW())
    </insert>

    <update id="update">
        UPDATE book
        SET book_name=#{bookName},author=#{author},isbn=#{isbn},stock=#{stock},update_time=NOW()
        WHERE id=#{id}
    </update>

    <delete id="deleteById">
        DELETE FROM book WHERE id=#{id}
    </delete>

    <update id="updateStock">
        UPDATE book SET stock = stock + #{num} WHERE id = #{id}
    </update>
</mapper>